# Server
PORT=3001
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...          # anon/public key (do painel Supabase > Settings > API)
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # service role key — NUNCA expor no frontend
DATABASE_URL=postgresql://user:password@localhost:5432/iris

# OpenAI
OPENAI_API_KEY=sk-proj-...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Admin
ADMIN_EMAIL=seu@email.com         # Promovido automaticamente para role=admin no startup

# Apify
APIFY_API_KEY=apify_api_...       # Chave de API do Apify (apify.com/settings/integrations)

# Email (Resend)
RESEND_API_KEY=re_...                # Chave de API do Resend (resend.com/api-keys)
RESEND_FROM_EMAIL=noreply@seudominio.com  # Remetente verificado no Resend

# Frontend (CORS)
FRONTEND_URL=http://localhost:5173
